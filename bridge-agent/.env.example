# ══════════════════════════════════════════════════
#  bridge-agent 설정 파일
#  이 파일을 .env 로 복사한 뒤 값을 입력하세요.
#  cp .env.example .env
# ══════════════════════════════════════════════════

# ─── 브라우저 옵션 ───────────────────────────────
# HEADLESS=true  → 백그라운드 실행 (운영)
# HEADLESS=false → 브라우저 창 표시 (디버그)
HEADLESS=true

# 오류 발생 시 스크린샷 저장 (bridge-agent/screenshots/)
SCREENSHOT_ON_ERROR=true

# 페이지 최대 대기시간 (ms)
PAGE_TIMEOUT=60000

# ─── 홈택스 (Hometax) ────────────────────────────
# false 로 설정하면 샘플 PDF 생성 (미연동 상태)
HOMETAX_ENABLED=true

# 세무사 홈택스 ID / 비밀번호
HOMETAX_USER_ID=세무사아이디
HOMETAX_USER_PW=비밀번호

# 공동인증서 로그인 사용 시 (선택)
# HOMETAX_CERT_PATH=C:\Users\XXX\AppData\LocalLow\NPKI\yessign\USER\...
# HOMETAX_CERT_PW=인증서비밀번호

# ─── 4대사회보험 정보연계센터 ────────────────────
# false 로 설정하면 샘플 PDF 생성
FOURINSURE_ENABLED=true

# 사업장 관리 담당자 ID / 비밀번호
FOURINSURE_USER_ID=4대보험아이디
FOURINSURE_USER_PW=비밀번호

# ─── 팝빌 (Popbill) — 홈택스 스크래핑 API ──────────
# false(기본값)이면 팝빌 연동 비활성화 (Playwright 방식만 사용)
POPBILL_ENABLED=false

# 팝빌 파트너 연동 ID / 보안키
# https://www.popbill.com → 파트너 관리 → 연동 정보
POPBILL_LINK_ID=팝빌링크ID
POPBILL_SECRET_KEY=팝빌시크릿키

# true = 테스트 환경, false = 운영 환경
POPBILL_IS_TEST=true

# 세무사(수임자) 사업자번호 (하이픈 없이 10자리)
POPBILL_AGENT_CORP_NUM=0000000000

# 팝빌 작업 완료 폴링 최대 대기시간 (ms)
POPBILL_POLL_TIMEOUT=120000
# 팝빌 폴링 간격 (ms)
POPBILL_POLL_INTERVAL=3000

# ─── Redis (BullMQ 큐) ────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=비밀번호  # 패스워드 설정 시 주석 해제

# ─── Solapi (카카오 알림톡/친구톡) ───────────────
# https://console.solapi.com → 개발 → API 키 관리
SOLAPI_API_KEY=NCSCOZY7QOM3Z3GG
SOLAPI_API_SECRET=41SHEEX8EAMW01X2QMHLHDWOCSGTBC0S
# 문자 발신번호 (Solapi 콘솔에서 사전 등록 필요)
SOLAPI_SENDER_NUMBER=
# 카카오 채널 pfId (Solapi 콘솔 → 카카오 → 채널 목록)
SOLAPI_KAKAO_PF_ID=
